<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr"
      crossorigin="anonymous"
    />

    <link rel="stylesheet" href="admin.css" />
  </head>

  <body id="dashboardPage" class="dashboard-page">
    <main>
      <%- include("../partials/sidebar") %>

      <div class="dashboard">
        <%- include("../partials/greeting&docCount") %>

        <div class="dashboard-contents">
          <% let sN = 1; %> <% for(let item of products ){ %>
          <div class="item-container">
            <span class="serial-number"><%= sN++ %></span>

            <div class="display-img-wrapper">
              <img src="<%= item.adminImg %>" alt="" />
            </div>

            <div class="anchor">
              <p class="chain item-name">
                <strong class="item"><%= item.title %></strong>

                <i class="bi bi-pencil-square text-primary i edit-icon"></i>

                <i class="bi bi-check-lg save-icon save-btn"></i>
              </p>
            </div>

            <div class="anchorT">
              <p class="chain item-price">
                <strong class="price"
                  >₦<%= item.price.toLocaleString() %></strong
                >
                <i
                  class="bi bi-pencil-square text-primary i edit-icon2"
                  data-product-name="<%= item.title %>"
                ></i>
                <i class="bi bi-check-lg save-icon2 save-btn"></i>
              </p>
            </div>

            <i
              class="bi bi-x-square rmv-icon"
              data-product-name="<%= item.title %>"
            ></i>
          </div>
          <% } %>
        </div>
      </div>
    </main>

    <script src="admin.js"></script>
  </body>
</html>
