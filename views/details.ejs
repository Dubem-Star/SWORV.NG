<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Details-page</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr"
      crossorigin="anonymous"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />

    <link
      href="https://res.cloudinary.com/dirijnb2k/image/upload/sworv-logo.png"
      type="image/png"
      rel="icon"
    />
    <link rel="stylesheet" href="app.css" />
  </head>
  <body id="detailsPage">
    <%- include("partials/navbar") %>

    <!-- PREVIEW IMAGES PREVIEW IMAGES PREVIEW IMAGES PREVIEW IMAGES  -->
    <main class="d-container">
      <div class="detail-row">
        <div class="mini-imgs h-100">
          <% for(let img of product.image) {%>
          <div class="prev-cont">
            <img src="<%= img %>" alt="preview-image" class="swap" />
          </div>
          <% } %>
        </div>

        <!-- PRODUCT IMAGE  PRODUCT IMAGE   PRODUCT IMAGE  PRODUCT IMAGE  -->
        <div class="img-col">
          <div class="zoom-col" id="zoomCont">
            <img
              src="<%= product.image[0] %>"
              class="product-img image-fluid"
              id="productImg"
              alt="product"
            />
          </div>
        </div>

        <div class="card description-col">
          <h4 class="detail-card-title" id="productName">
            <%= product.title %>
          </h4>
          <p class="card-text lead info" id="productDescription">
            <%= product.description %>
          </p>

          <div class="product-size-container" id="productSizeBox">
            <div class="size-input-wrapper">
              <label for="productSize" class="label-text">
                <strong>Size:</strong></label
              >
              <select
                name="size"
                class="form-control size-selection"
                id="productSize"
                required
              >
                <option value="" disabled selected hidden>
                  --select size--
                </option>
                <option value="Small">small</option>
                <option value="Medium">medium</option>
                <option value="Large">large</option>
                <option value="XtraLarge">xtraLarge</option>
                <option value="XxtraLarge">xxLarge</option>
              </select>
            </div>

            <span id="cautionMsg" class="caution-message"
              ><i class="bi bi-exclamation-triangle"></i> kindly select a
              size</span
            >
          </div>

          <span class="card-text price-text" id="productPrice">
            ₦<%= product.price.toLocaleString() %></span
          >
          <br />
          <button class="btn btn-primary atc-btn" id="atcBtn">
            Add to cart
          </button>
        </div>
      </div>
    </main>

    <section class="carousel">
      <section class="carousel-header">
        <h5 lead>Keep Shopping</h5>
      </section>
      <div class="mini-container">
        <div class="scroll">
          <i class="bi bi-chevron-left arrow"></i>
        </div>
        <div class="related-products-carousel">
          <% for(let item of products){ %>
          <a href="/details?id=<%= item._id %>">
            <div class="carousel-product-card">
              <img
                src="<%= item.image[0] %>"
                alt="carousel-img"
                class="carousel-img"
              />
            </div>
          </a>

          <% } %>
        </div>
        <div class="scroll">
          <i class="bi bi-chevron-right arrow"></i>
        </div>
      </div>
    </section>

    <%- include("partials/footer") %>

    <script src="include.js" defer></script>
    <script src="app.js" defer></script>
  </body>
</html>
